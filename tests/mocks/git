#!/usr/bin/env bash
# Mock git CLI for testing

case "$1" in
    rev-parse)
        if [[ "$2" == "--git-dir" ]]; then
            if [[ "${MOCK_GIT_NOT_IN_REPO:-}" == "true" ]]; then
                echo "fatal: not a git repository (or any of the parent directories): .git" >&2
                exit 128
            fi
            echo ".git"
        elif [[ "$2" == "--short" ]]; then
            echo "${MOCK_REV_PARSE_SHORT:-abc123d}"
        else
            echo "${MOCK_REV_PARSE:-abc123def456789}"
        fi
        ;;
    log)
        # Pretend no unpushed commits
        echo ""
        ;;
    branch)
        if [[ "$2" == "--show-current" ]]; then
            echo "main"
        fi
        ;;
    *)
        echo "Mock git: unknown command $*" >&2
        exit 1
        ;;
esac
